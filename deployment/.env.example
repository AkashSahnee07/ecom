# Copy to deployment/.env and adjust for your environment
# cp deployment/.env.example deployment/.env

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce123
POSTGRES_PORT=5432

# ── MySQL ───────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=product_db
MYSQL_USER=product_user
MYSQL_PASSWORD=product123
MYSQL_PORT=3306

# ── Redis / MongoDB / Kafka ─────────────────────────────────
REDIS_PORT=6379
MONGODB_PORT=27017
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DATABASE=recommendation_db
KAFKA_PORT=9092

# ── Tracing & Metrics ───────────────────────────────────────
ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ── JWT (must match all microservices) ──────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string

# ── Optional admin tools (profile: tools) ───────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@ecommerce.com
PGADMIN_PASSWORD=admin123
MONGO_EXPRESS_PORT=8091

# ── Optional log stack (profile: logs) ──────────────────────
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# ── Kubernetes / production ─────────────────────────────────
EUREKA_URL=http://eureka-server:8761/eureka/
CONFIG_SERVER_URL=http://config-server:8888
TRACING_SAMPLING=0.1
